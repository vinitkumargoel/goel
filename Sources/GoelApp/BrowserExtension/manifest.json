{
  "manifest_version": 3,
  "name": "GoelDownloader Capture",
  "version": "1.0",
  "description": "Send downloads to GoelDownloader on your Mac. Toolbar button toggles capture; right-click any link or media for one-off sends.",
  "key": "",
  "permissions": ["downloads", "contextMenus", "nativeMessaging", "storage"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "GoelDownloader — click to toggle download capture"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "goel@goeldownloader.app",
      "strict_min_version": "115.0"
    }
  }
}
